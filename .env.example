# Railway auto-provides DATABASE_URL when you add PostgreSQL
# Just make sure to set these:

DATABASE_URL=postgresql://user:password@localhost:5432/band_app
JWT_SECRET=your-super-secret-key-change-this-in-production
NODE_ENV=production
PORT=3000

# WD MyCloud Configuration
# Set this to your WD MyCloud network path where you want audio files stored
# Linux/Mac example: /mnt/MyCloudShares/Casiopony
# Windows example: \\192.168.1.100\Casiopony
# If not set, files will be stored in local /uploads folder (Railway won't work for this)
MYCLOUD_PATH=/mnt/MyCloudShares/Casiopony
